// ── IE-06: Dead Letter Queue ─────────────────────────────────────────────────
// Tracks persistently failing sensor+domain combinations.
// After DEAD_LETTER_THRESHOLD (5) failures, the pair is skipped on future scans.

model IntelScanDeadLetter {
  id            Int       @id @default(autoincrement())
  tenantId      Int       @map("tenant_id")
  sensorId      String    @map("sensor_id")
  targetDomain  String    @map("target_domain")
  errorMessage  String    @map("error_message")
  attemptCount  Int       @default(1) @map("attempt_count")
  firstFailedAt DateTime  @default(now()) @map("first_failed_at")
  lastAttemptAt DateTime  @default(now()) @map("last_attempt_at")
  resolvedAt    DateTime? @map("resolved_at")

  @@index([tenantId, resolvedAt])
  @@index([tenantId, sensorId])
  @@map("intel_scan_dead_letters")
}
