  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  verticalType   String?  @map("vertical_type")

  @@map("tenants")
}

model Site {
  id                    Int                     @id @default(autoincrement())
  tenantId              Int
  slug                  String
  domain                String
  displayName           String
  niche                 String?
  category              String?
  status                SiteStatus              @default(ACTIVE)
  launchDate            DateTime?
  acquisitionDate       DateTime?
  acquisitionCost       Float?
  monthlyRevenueCurrent Float?
  monthlyTrafficCurrent Int?
  domainAuthority       Int?
  domainRating          Int?
  cms                   String?
  hostingProvider       String?
  hostingCostMonthly    Float?
  monetizationMix       String                  @default("both")
  gscPropertyId         String?
  ga4PropertyId         String?
  gscConnectedAt        DateTime?
  ga4ConnectedAt        DateTime?
  notes                 String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  acquisitionTarget     AcquisitionTarget?
  contentBriefs         AffiliateContentBrief[]
  affiliatePrograms     AffiliateProgram[]
  adNetworks            DisplayAdNetwork[]
  revenueEntries        RevenueEntry[]
  valuations            SiteValuation[]
  intelAsset            IntelAsset?

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model AffiliateProgram {
  id                Int                    @id @default(autoincrement())
  tenantId          Int
  siteId            Int
  networkName       String
  merchantName      String
  merchantUrl       String?
  commissionRate    Float?
  commissionType    String                 @default("percent")
  cookieWindowDays  Int?
  payoutThreshold   Float?
  paymentSchedule   String?
  applicationStatus AffiliateProgramStatus @default(NOT_APPLIED)
  approvedDate      DateTime?
  lifetimeEarnings  Float                  @default(0)
  lastPayoutAmount  Float?
  lastPayoutDate    DateTime?
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  site              Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([tenantId, siteId])
}

model DisplayAdNetwork {
  id                      Int             @id @default(autoincrement())
  tenantId                Int
  siteId                  Int
  networkName             String
  status                  AdNetworkStatus @default(NOT_QUALIFIED)
  monthlySessionsRequired Int?
  currentMonthlySessions  Int?
  currentRPM              Float?
  monthlyRevenueCurrent   Float?
  activeSince             DateTime?
  notes                   String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  site                    Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([tenantId, siteId])
}

model RevenueEntry {
  id         Int               @id @default(autoincrement())
  tenantId   Int
  siteId     Int
  month      Int
  year       Int
  sourceType RevenueSourceType
  sourceName String
  revenue    Float
  sessions   Int?
  pageviews  Int?
  clicks     Int?
  rpm        Float?
  epc        Float?
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  site       Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([tenantId, siteId, month, year, sourceType, sourceName])
  @@index([tenantId, siteId])
}

model AcquisitionTarget {
  id                    Int              @id @default(autoincrement())
  tenantId              Int
  siteId                Int?             @unique
  domain                String
  niche                 String?
  category              String?
  stage                 AcquisitionStage @default(RESEARCHING)
  source                String?
  askingPrice           Float?
  offeredPrice          Float?
  purchasePrice         Float?
  currentMonthlyTraffic Int?
  currentMonthlyRevenue Float?
  domainAuthority       Int?
  domainAge             Int?
  broker                String?
  dueDiligenceNotes     String?
  decisionNotes         String?
  targetPurchaseDate    DateTime?
  purchasedDate         DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  site                  Site?            @relation(fields: [siteId], references: [id])

  @@index([tenantId])
}

model AffiliateContentBrief {
  id                       Int         @id @default(autoincrement())
  tenantId                 Int
  siteId                   Int
  targetKeyword            String
  searchVolume             Int?
  keywordDifficulty        Int?
  contentType              ContentType @default(ARTICLE)
  assignedWriterName       String?
  wordCountTarget          Int?
  status                   BriefStatus @default(BRIEFED)
  dueDate                  DateTime?
  publishedDate            DateTime?
  publishedUrl             String?
  currentRankingPosition   Int?
  peakRankingPosition      Int?
  currentMonthlyTraffic    Int?
  attributedMonthlyRevenue Float?
  lastRankCheck            DateTime?
  lastTrafficPull          DateTime?
  refreshDue               Boolean     @default(false)
  notes                    String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  site                     Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([tenantId, siteId])
}

model SiteValuation {
  id                  Int                    @id @default(autoincrement())
  tenantId            Int
  siteId              Int
  valuationDate       DateTime               @default(now())
  monthlyNetProfit    Float
  multipleUsed        Float                  @default(36)
  estimatedValue      Float
  brokerListingStatus ValuationListingStatus @default(NOT_LISTED)
  listedPrice         Float?
  salePrice           Float?
  saleDate            DateTime?
  broker              String?
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  site                Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([tenantId, siteId])
}

model IntelAssetGroup {
  id              Int               @id @default(autoincrement())
  tenantId        Int               @map("tenant_id")
  name            String
  type            String
  healthScore     Int               @default(50) @map("health_score")
  status          String            @default("active")
  clientProfileId Int?              @unique @map("client_profile_id")
  verticalMeta    Json?             @map("vertical_meta")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  clientProfile   ClientProfile?    @relation(fields: [clientProfileId], references: [id])
  assets          IntelAsset[]
  competitors     IntelCompetitor[]
  scans           IntelScan[]

  @@index([tenantId])
  @@map("intel_asset_groups")
}

model IntelAsset {
  id             Int               @id @default(autoincrement())
  tenantId       Int               @map("tenant_id")
  assetGroupId   Int?              @map("asset_group_id")
  domain         String
  name           String
  type           String
  ownershipModel String            @default("managed") @map("ownership_model")
  status         String            @default("active")
  healthScore    Int               @default(50) @map("health_score")
  lastScanAt     DateTime?         @map("last_scan_at")
  nextScanAt     DateTime?         @map("next_scan_at")
  clientDomainId Int?              @unique @map("client_domain_id")
  siteId         Int?              @unique @map("site_id")
  verticalMeta   Json?             @map("vertical_meta")
  fleetId        Int?              @map("fleet_id")
  fleetRole      String?           @map("fleet_role")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  assetGroup     IntelAssetGroup?  @relation(fields: [assetGroupId], references: [id])
  clientDomain   ClientDomain?     @relation(fields: [clientDomainId], references: [id])
  site           Site?             @relation(fields: [siteId], references: [id])
  fleet          IntelFleet?       @relation(fields: [fleetId], references: [id])
  fingerprint    IntelFingerprint?
  competitors    IntelCompetitor[]
  snapshots      IntelSnapshot[]
  similarityScoresA IntelSimilarityScore[] @relation("SimilarityAssetA")
  similarityScoresB IntelSimilarityScore[] @relation("SimilarityAssetB")
  indexHealth       IntelIndexHealth[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([assetGroupId])
  @@index([fleetId])
  @@map("intel_assets")
}

model IntelCompetitor {
  id            Int              @id @default(autoincrement())
  tenantId      Int              @map("tenant_id")
  assetGroupId  Int?             @map("asset_group_id")
  assetId       Int?             @map("asset_id")
  name          String
  domain        String?
  googlePlaceId String?          @map("google_place_id")
  isActive      Boolean          @default(true) @map("is_active")
  source        String           @default("manual")
  createdAt     DateTime         @default(now()) @map("created_at")
  assetGroup    IntelAssetGroup? @relation(fields: [assetGroupId], references: [id])
  asset         IntelAsset?      @relation(fields: [assetId], references: [id])
  snapshots     IntelSnapshot[]

  @@index([tenantId])
  @@index([assetGroupId])
  @@index([assetId])
  @@map("intel_competitors")
}

model IntelSensorCredential {
  id          Int       @id @default(autoincrement())
  tenantId    Int       @map("tenant_id")
  sensorId    String    @map("sensor_id")
  credentials Json
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  status      String    @default("active")
  statusNote  String?   @map("status_note")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, sensorId])
  @@index([tenantId])
  @@map("intel_sensor_credentials")
}

model IntelScan {
  id             Int              @id @default(autoincrement())
  tenantId       Int              @map("tenant_id")
  assetGroupId   Int?             @map("asset_group_id")
  scheduledAt    DateTime         @map("scheduled_at")
  startedAt      DateTime?        @map("started_at")
  completedAt    DateTime?        @map("completed_at")
  status         String           @default("scheduled")
  sensorsRun     Json?            @map("sensors_run")
  sensorsFailed  Json?            @map("sensors_failed")
  snapshotCount  Int              @default(0) @map("snapshot_count")
  alertCount     Int              @default(0) @map("alert_count")
  tasksGenerated Int              @default(0) @map("tasks_generated")
  apiCosts       Json?            @map("api_costs")
  createdAt      DateTime         @default(now()) @map("created_at")
  assetGroup     IntelAssetGroup? @relation(fields: [assetGroupId], references: [id])
  snapshots      IntelSnapshot[]

  @@index([tenantId, status])
  @@index([assetGroupId])
  @@map("intel_scans")
}

model IntelSnapshot {
  id           Int              @id @default(autoincrement())
  scanId       Int              @map("scan_id")
  entityType   String           @map("entity_type")
  assetId      Int?             @map("asset_id")
  competitorId Int?             @map("competitor_id")
  metrics      Json
  deltas       Json?
  velocity     Json?
  alerts       Json?
  createdAt    DateTime         @default(now()) @map("created_at")
  asset        IntelAsset?      @relation(fields: [assetId], references: [id])
  competitor   IntelCompetitor? @relation(fields: [competitorId], references: [id])
  scan         IntelScan        @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([assetId, createdAt(sort: Desc)])
  @@index([competitorId, createdAt(sort: Desc)])
  @@map("intel_snapshots")
}

// ─── IE-04: Fleet Diversity Engine ───────────────────────────────────────────

model IntelFleet {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @map("tenant_id")
  name           String
  assetGroupId   Int?      @map("asset_group_id")

  diversityScore Float     @default(1.0) @map("diversity_score")
  lastAuditAt    DateTime? @map("last_audit_at")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  assets           IntelAsset[]
  fingerprints     IntelFingerprint[]
  similarityScores IntelSimilarityScore[]

  @@index([tenantId])
  @@map("intel_fleets")
}

model IntelFingerprint {
  id      Int @id @default(autoincrement())
  assetId Int @unique @map("asset_id")
  fleetId Int @map("fleet_id")

  // Template architecture
  navPattern          String? @map("nav_pattern")
  contentHierarchy    String? @map("content_hierarchy")
  urlStructure        String? @map("url_structure")
  internalLinkPattern String? @map("internal_link_pattern")
  footerStructure     String? @map("footer_structure")
  ctaPattern          String? @map("cta_pattern")

  // Visual identity
  primaryFont      String? @map("primary_font")
  secondaryFont    String? @map("secondary_font")
  colorPalette     Json?   @map("color_palette")
  componentLibrary String? @map("component_library")
  imageTreatment   String? @map("image_treatment")
  overallAesthetic String? @map("overall_aesthetic")

  // Infrastructure
  hostingProvider   String? @map("hosting_provider")
  framework         String?
  headTagOrder      Json?   @map("head_tag_order")
  schemaMarkupTypes Json?   @map("schema_markup_types")
  robotsTxtHash     String? @map("robots_txt_hash")
  sitemapFormat     String? @map("sitemap_format")
  sslProvider       String? @map("ssl_provider")

  // Content signals
  avgWordCount      Int?    @map("avg_word_count")
  contentCadence    String? @map("content_cadence")
  toneProfile       String? @map("tone_profile")
  authorAttribution String? @map("author_attribution")
  mediaUsage        String? @map("media_usage")

  // Link topology
  fleetCrossLinks        Int   @default(0) @map("fleet_cross_links")
  anchorTextDistribution Json? @map("anchor_text_distribution")

  // Registration
  registrationDate DateTime? @map("registration_date")
  registrar        String?

  lastUpdatedAt DateTime @default(now()) @map("last_updated_at")

  asset IntelAsset @relation(fields: [assetId], references: [id])
  fleet IntelFleet @relation(fields: [fleetId], references: [id])

  @@index([fleetId])
  @@map("intel_fingerprints")
}

model IntelSimilarityScore {
  id       Int @id @default(autoincrement())
  fleetId  Int @map("fleet_id")
  assetAId Int @map("asset_a_id")
  assetBId Int @map("asset_b_id")

  templateSimilarity       Float @map("template_similarity")
  visualSimilarity         Float @map("visual_similarity")
  infrastructureSimilarity Float @map("infrastructure_similarity")
  contentSimilarity        Float @map("content_similarity")
  linkSimilarity           Float @map("link_similarity")
  compositeScore           Float @map("composite_score")

  calculatedAt DateTime @default(now()) @map("calculated_at")

  fleet  IntelFleet @relation(fields: [fleetId], references: [id])
  assetA IntelAsset @relation("SimilarityAssetA", fields: [assetAId], references: [id])
  assetB IntelAsset @relation("SimilarityAssetB", fields: [assetBId], references: [id])

  @@index([fleetId])
  @@index([assetAId])
  @@index([assetBId])
  @@map("intel_similarity_scores")
}

// Platform-wide pool — all tenants draw from the same options.
// Fingerprints are entered manually during site builds (future: automated crawl).
model IntelTemplatePool {
  id        Int      @id @default(autoincrement())
  dimension String   // "template" | "font_stack" | "color_palette" | "nav_pattern" | "url_structure" | "schema_types"
  name      String   // human-readable label
  value     Json     // the configuration/metadata for this pool entry
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([dimension, name])
  @@map("intel_template_pool")
}

// ─── Enums ────────────────────────────────────────────────────────────────────


// IE-05: Index Health - populated from GSC sensor data after each scan

model IntelIndexHealth {
  id              Int       @id @default(autoincrement())
  assetId         Int       @map("asset_id")
  scanId          Int?      @map("scan_id")

  pagesSubmitted  Int?      @map("pages_submitted")
  pagesIndexed    Int?      @map("pages_indexed")
  indexRatio      Float?    @map("index_ratio")
  crawlErrors     Json?     @map("crawl_errors")
  indexVelocity   Float?    @map("index_velocity")
  sitemapValid    Boolean?  @map("sitemap_valid")
  manualActions   Json?     @map("manual_actions")

  deltas          Json?

  createdAt       DateTime  @default(now()) @map("created_at")

  asset           IntelAsset @relation(fields: [assetId], references: [id])

  @@index([assetId, createdAt(sort: Desc)])
  @@map("intel_index_health")
}

