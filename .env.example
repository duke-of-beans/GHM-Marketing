# =============================================================================
# COVOS Platform — Environment Variables
# Copy to .env.local and fill in real values
#
# Sprint 34 Classification:
#   PLATFORM  = COVOS infrastructure, stays in platform env
#   TENANT    = Per-tenant credential, migrating to Tenant DB row
#   TODO: COVOS_ACCOUNT_NEEDED = Currently under GHM account, needs COVOS-owned account
# =============================================================================

# ── PLATFORM: Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/ghm_dashboard?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/ghm_dashboard?sslmode=require"

# ── PLATFORM: Auth ──────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── PLATFORM: External APIs ─────────────────────────────────────────────────
# Outscraper - Business data enrichment ($5 credit to start)
OUTSCRAPER_API_KEY=""

# Ahrefs - SEO metrics ($29/mo Lite plan)
AHREFS_API_TOKEN=""

# Google PageSpeed - Site speed analysis (FREE)
PAGESPEED_API_KEY=""

# ── TODO: COVOS_ACCOUNT_NEEDED — Stock Photos (T-006, T-007) ────────────────
# Current: registered under GHM / personal accounts
# Target: COVOS Platform accounts — see THIRD_PARTY_MIGRATION.md
# Unsplash: https://unsplash.com/developers — requires attribution in UI (handled automatically)
UNSPLASH_ACCESS_KEY=""
# Pexels: https://www.pexels.com/api/ — no attribution required
PEXELS_API_KEY=""

# ── TODO: COVOS_ACCOUNT_NEEDED — GIF Search (T-005) ─────────────────────────
# Current: GHM Tenor key / demo fallback
# Target: COVOS Platform Tenor API key
TENOR_API_KEY=""

# ── TODO: COVOS_ACCOUNT_NEEDED — Email (INFRA-003) ──────────────────────────
# Current: GHM Resend account
# Target: COVOS Resend account with covos.app domain verified
RESEND_API_KEY=""
# TENANT: FROM_EMAIL is now per-tenant — read from Tenant.fromEmail row
FROM_EMAIL="noreply@ghmmarketing.com"

# ── TODO: COVOS_ACCOUNT_NEEDED — Blob Storage (INFRA-005) ───────────────────
# Current: ghm-marketing-blob (IAD1, Public)
# Target: COVOS Platform Blob store, paths namespaced by tenant slug
BLOB_READ_WRITE_TOKEN=""

# ── PLATFORM: Cron ──────────────────────────────────────────────────────────
CRON_SECRET="generate-with-openssl-rand-base64-32"

# ── TODO: COVOS_ACCOUNT_NEEDED — Google Ads (T-003, INFRA-004) ──────────────
# Current: GHM Google Ads credentials
# Target: COVOS MCC account + per-tenant OAuth
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_REDIRECT_URI="https://your-domain.com/api/oauth/google-ads/callback"

# ── TODO: COVOS_ACCOUNT_NEEDED — GBP OAuth (T-002, INFRA-004) ───────────────
# Current: GHM GCP project
# Target: COVOS Platform GCP project (submit for Google review ASAP)
# GBP_CLIENT_ID=""
# GBP_CLIENT_SECRET=""

# ── TODO: COVOS_ACCOUNT_NEEDED — DataForSEO (T-004) ─────────────────────────
# Current: registered under GHM
# Target: COVOS Platform DataForSEO account
# DATAFORSEO_LOGIN=""
# DATAFORSEO_PASSWORD=""

# ── PLATFORM: Domain Registrar ──────────────────────────────────────────────
GODADDY_API_KEY=""
GODADDY_API_SECRET=""
GODADDY_ENVIRONMENT="production"

# ── PLATFORM: Multi-tenant ──────────────────────────────────────────────────
# Root domain for subdomain resolution — do not include trailing slash
ROOT_DOMAIN="covos.app"

# ── PLATFORM: Telemetry ────────────────────────────────────────────────────
COVOS_TELEMETRY_ENDPOINT=""
COVOS_TENANT_SLUG="ghm"

# ── TENANT: covosdemo database ──────────────────────────────────────────────
# Target: migrates to Tenant.databaseUrl row
COVOS_TEST_DATABASE_URL=""
COVOS_TEST_DIRECT_URL=""
